// InsideBank Tools — Owner Dashboard
// Isolated DB: insidebank_tools
// User: insidebank_tools_user

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Prisma Adapter tables ─────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  // LINE Login
  lineUserId      String? @unique
  lineDisplayName String?

  // Optional: foreign reference to lms_platform.users for SSO
  lmsUserId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts   Account[]
  sessions   Session[]
  businesses Business[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Business domain ───────────────────────────────────────

model Business {
  id       String @id @default(cuid())
  userId   String
  name     String
  template String @default("ibf") // "ibf" = Inside Business Finance, "ib" = Inside Bank

  // C17 — "set once" per business, not per month
  monthlyDebtService Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyEntries MonthlyEntry[]
  expenseItems   ExpenseItem[]
  leakChecks     LeakCheck[]
  sessionData    SessionData[]

  // MVP: 1 user = 1 business. Remove in Phase 4 for multi-business.
  @@unique([userId])
}

model MonthlyEntry {
  id         String @id @default(cuid())
  businessId String

  // Report month — always 1st of month (e.g. 2024-01-01)
  month DateTime @db.Date

  // === 9 numbers from Owner Dashboard sheet ===
  grossSales    Decimal? @db.Decimal(15, 2) // C9
  creditSales   Decimal? @db.Decimal(15, 2) // C10 (subset of grossSales)
  cogs          Decimal? @db.Decimal(15, 2) // C11
  otherExpenses Decimal? @db.Decimal(15, 2) // C12
  cashIn        Decimal? @db.Decimal(15, 2) // C13
  arBalance     Decimal? @db.Decimal(15, 2) // C14
  apBalance     Decimal? @db.Decimal(15, 2) // C15
  cashOnHand    Decimal? @db.Decimal(15, 2) // C16

  // === 1 text note ===
  leakNote String? @db.Text // C18

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, month])
  @@index([businessId, month])
}

// ─── S5 Expense Map ───────────────────────────────────────

model ExpenseItem {
  id         String @id @default(cuid())
  businessId String

  name     String  // รายการค่าใช้จ่าย
  category String  // "ลงทุน" | "ดำเนินงาน" | "สูญเปล่า"
  amount   Decimal @db.Decimal(15, 2) // บาท/เดือน
  decision String? // "ตัด" | "เพิ่ม" | "ปรับ" | null

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model LeakCheck {
  id         String @id @default(cuid())
  businessId String

  // 1-10 matching the 10 checkpoints in template
  checkNumber Int
  found       Boolean  @default(false) // ✓ = true
  leakAmount  Decimal? @db.Decimal(15, 2) // เงินรั่ว/เดือน (ประมาณ)
  fixPlan     String?  @db.Text // แผนแก้

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, checkNumber])
  @@index([businessId])
}

// ─── Session Data (flexible model for S1-S7) ─────────────

enum SessionType {
  S1_CHECK_CASH
  S2A_INCOME_STATEMENT
  S2B_CASHFLOW_2YR
  S3_CASHFLOW_4LAYERS
  S4A_PRICING
  S4B_CM
  S4C_REAL_PROFIT
  S6_FIVE_BUCKETS
  S7_BUSINESS_PLAN
  // Inside Bank — Business MRI
  IB_IDENTITY
  IB_FINANCIAL_MRI
  IB_CASH_DNA
  IB_BANK_VIEW
  IB_CAPITAL_DESIGN
  IB_GROWTH_CAPACITY
  IB_LOAN_ACTION
}

model SessionData {
  id          String      @id @default(cuid())
  businessId  String
  sessionType SessionType
  month       DateTime?   @db.Date // optional — some sessions are not monthly
  data        Json        // raw inputs from user
  computed    Json        // server-computed results
  verdict     String?     // green | yellow | red

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, sessionType, month])
  @@index([businessId, sessionType])
}

// ─── Analytics ─────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // "entry_created", "entry_updated", "dashboard_viewed", "login", etc.
  meta      Json?  // { month: "2024-01", source: "line" } etc.
  createdAt DateTime @default(now())

  @@index([userId, action])
  @@index([createdAt])
}
